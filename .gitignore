# Node / Next.js
node_modules/
.next/
out/
dist/
.vercel/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Environment files — never commit credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Personal resume — every user keeps their own at docs/resume.md; the
# example template at docs/resume.example.md IS committed. The
# *[Rr]esume* glob is belt-and-suspenders against accidentally
# committing a copy with a different filename (e.g. "Master Resume.md").
docs/resume.md
docs/*[Rr]esume*
!docs/resume.example.md

# Personal config overrides. The committed config/*.example.json files
# ship public defaults; create a sibling config/<name>.json to override
# locally. Production overrides come from env vars (see SETUP.md).
config/*.json
!config/*.example.json

# Optional personal scripts directory — for one-off tools you carry
# across machines but don't want in the public repo.
scripts/private/

# Personal screenshots — anything prefixed personal- is git-ignored so
# users can keep their own captures locally. The placeholder screenshot
# files committed to the repo do NOT use the personal- prefix.
screenshots/personal-*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
