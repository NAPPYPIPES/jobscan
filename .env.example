# Copy this file to .env.local and fill in real values. Never commit
# .env.local — it's gitignored. Vercel deployments read their values
# from the Vercel dashboard, not from any committed file.

# ────────────────────────────────────────────────────────────────────
# Required for everything
# ────────────────────────────────────────────────────────────────────

# Neon Postgres connection string. Get from Neon dashboard → your
# project → Connection Details → "Pooled connection" works for
# serverless (Vercel) and CLI scripts alike.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Anthropic API key for fit scoring + Pro/Con summaries. Get from
# console.anthropic.com → API Keys. Free credit covers initial setup.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Single-password authentication for the web UI. Pick a long passphrase
# you'll remember — there's no recovery flow.
PERSONAL_PASS=correct-horse-battery-staple

# Secret used to sign the session cookie. Any high-entropy string;
# rotating it invalidates every existing cookie. Generate with e.g.
# `openssl rand -base64 32`.
AUTH_SECRET=replace-me-with-a-random-32-byte-string

# ────────────────────────────────────────────────────────────────────
# Required for the daily email digest
# ────────────────────────────────────────────────────────────────────

# Resend API key. Get from resend.com → API Keys.
RESEND_API_KEY=re_...

# From / to addresses for the daily digest. The "from" address must be
# on a domain you've verified with Resend.
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_TO_EMAIL=you@yourdomain.com

# ────────────────────────────────────────────────────────────────────
# Required for the production cron (GitHub Actions → Vercel)
# ────────────────────────────────────────────────────────────────────

# Any high-entropy string. GitHub Actions sends this as a Bearer token
# in the Authorization header; the cron routes refuse the request
# unless it matches. Locally, leaving CRON_SECRET unset disables the
# check so smoke tests don't need it.
CRON_SECRET=replace-me-with-another-random-string
