# Copy this file to .env.local and fill in real values. Never commit
# .env.local — it's gitignored. Vercel deployments read their values
# from the Vercel dashboard, not from any committed file.

# ────────────────────────────────────────────────────────────────────
# Required for everything
# ────────────────────────────────────────────────────────────────────

# Neon Postgres connection string. Get from Neon dashboard → your
# project → Connection Details → "Pooled connection" works for
# serverless (Vercel) and CLI scripts alike.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Anthropic API key for fit scoring + Pro/Con summaries. Get from
# console.anthropic.com → API Keys. Free credit covers initial setup.
ANTHROPIC_API_KEY=sk-ant-api03-...

# NextAuth (Auth.js v5) secret. Signs the JWT session token. Rotate to
# force every user to re-authenticate. Generate with `openssl rand -base64 32`.
AUTH_SECRET=replace-me-with-a-random-32-byte-string

# Email of the deployment's "maintainer" account — the user that gets
# seeded with the deterministic UUID and the high spend cap. On first
# Google sign-in matching this address, NextAuth links the OAuth login
# to the pre-seeded row instead of creating a duplicate.
#
# Required for migrations 0003 + 0005 to seed correctly. If you skip
# setting this, both migrations fall back to the non-resolving
# `maintainer@pub-ats-radar.local` alias — workable for a throwaway dev
# DB but the seeded maintainer row won't link to your Google login.
MAINTAINER_EMAIL=you@yourdomain.com

# Google OAuth credentials. Required for "Sign in with Google".
#
# Setup:
#   1. Go to https://console.cloud.google.com → APIs & Services →
#      Credentials → Create Credentials → OAuth client ID.
#   2. Application type: Web application.
#   3. Authorized redirect URIs (add ALL of these):
#        http://localhost:3000/api/auth/callback/google   (local dev)
#        https://YOUR_DOMAIN/api/auth/callback/google     (production)
#   4. Copy the client ID + secret into the two vars below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: explicit URL for NextAuth callbacks. Auto-detected on
# Vercel; only set this for non-Vercel hosting or unusual local setups.
# AUTH_URL=https://your-domain.com

# ────────────────────────────────────────────────────────────────────
# Required for the daily email digest
# ────────────────────────────────────────────────────────────────────

# Resend API key. Get from resend.com → API Keys.
RESEND_API_KEY=re_...

# From address for the daily digest. Must be on a domain you've
# verified with Resend. Recipients come from user_extras.digest_email
# (or users.email as fallback) — one email per onboarded user with
# digest_enabled=true.
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ────────────────────────────────────────────────────────────────────
# Required for the production cron (GitHub Actions → Vercel)
# ────────────────────────────────────────────────────────────────────

# Any high-entropy string. GitHub Actions sends this as a Bearer token
# in the Authorization header; the cron routes refuse the request
# unless it matches. Locally, leaving CRON_SECRET unset disables the
# check so smoke tests don't need it.
CRON_SECRET=replace-me-with-another-random-string
